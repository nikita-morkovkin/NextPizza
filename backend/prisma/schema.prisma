generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String      @id @default(uuid())

  fullName  String
  email     String   @unique
  password  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id        String      @id @default(uuid())
  
  name      String
  price     Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}